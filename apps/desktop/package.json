{
  "name": "@peep/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Peep desktop application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "publish:app": "electron-vite build && electron-builder --publish always",
    "build:win": "electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@peep/agent": "workspace:*",
    "@peep/flutter-adapter": "workspace:*",
    "@peep/platform-core": "workspace:*",
    "@peep/shared": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^4.0.3",
    "diff": "^7.0.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "emmet-monaco-es": "^5.7.0",
    "monaco-editor": "^0.52.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png2icons": "^2.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
